# Copy this file to `.env` and fill in secrets. Never commit real keys to `.env.example`.

# OpenAI (optional — app uses mock orchestration if unset)
OPENAI_API_KEY=

# CORS — comma-separated origins for production (e.g. https://app.example.com)
CORS_ORIGINS=http://localhost:3000

# Email — Resend API (https://resend.com) or leave empty for mock
RESEND_API_KEY=
EMAIL_FROM=Kyron Medical <appointments@example.com>


# Voice handoff — Vapi (https://vapi.ai) — demo mode if API key / assistant / phone id is missing
# Post-call webhook: set Server URL in the Vapi assistant to your public HTTPS URL + /api/voice/vapi-webhook
# (optional note below — not sent on API create-call)
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
# VAPI_WEBHOOK_URL=https://YOUR-TUNNEL.trycloudflare.com/api/voice/vapi-webhook

# SMS — Textbelt (https://textbelt.com) and/or Twilio
# auto = use TEXTBELT_API_KEY if set, else Twilio if all three Twilio vars set, else mock
SMS_PROVIDER=auto
# Purchased key or `textbelt` for one free test/day (see Textbelt docs)
TEXTBELT_API_KEY=
# Twilio (optional; trial accounts can only text verified numbers)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
